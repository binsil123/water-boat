float calculateTDS(float voltage) 
{
  float compensationCoefficient = 1.0 + 0.02 * (temperature - 25.0); // Temperature compensation
  float compensationVoltage = voltage / compensationCoefficient;
  return (compensationVoltage * TDS_FACTOR) * 1000; // Convert to ppm
}


void setup()
{
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(mot, OUTPUT);
  pinMode(phpin, INPUT);

  Serial.begin(115200);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

  Serial.print("Connecting to Wi-Fi");
  while (WiFi.status() != WL_CONNECTED)
  {
    Serial.print(".");
    delay(300);
  }
  Serial.println();
  Serial.print("Connected with IP: ");
  Serial.println(WiFi.localIP());
  Serial.println();
  
  config.api_key = API_KEY;
  auth.user.email = USER_EMAIL;
  auth.user.password = USER_PASSWORD;
  config.database_url = DATABASE_URL;
  Firebase.reconnectNetwork(true);
  fbdo.setBSSLBufferSize(4096 /* Rx buffer size in bytes from 512 - 16384 */, 1024 /* Tx buffer size in bytes from 512 - 16384 */);

  fbdo.setResponseSize(2048);

  Firebase.begin(&config, &auth);

  Firebase.setDoubleDigits(5);

  config.timeout.serverResponse = 10 * 1000;
  Blynk.begin(BLYNK_AUTH_TOKEN, WIFI_SSID, WIFI_PASSWORD);
  stopMotors();
}

void loop()
{
  unsigned long currentMillis = millis();
  if (currentMillis - previousMillis >= interval) 
  {
    previousMillis = currentMillis;
    fetch();
  }
  
  Blynk.run();
  timer.run();
  
}

void fetch()
{
  int rawADC = analogRead(TDS_PIN);                     
  float voltage = (rawADC * VREF) / ADC_RES;             
  float tdsValue = calculateTDS(voltage);
  Serial.print("TDS Value: ");
  Serial.print(tdsValue);
  Serial.println(" ppm");

  int analogValue = analogRead(turbidityPin);
  int turbidity = map(analogValue, 2140,2200, 5, 0);
  Serial.print(" V | Turbidity: ");
  Serial.println(turbidity);

  int temp = module1.readCelsius(); 
  Serial.print("Temperature: ");
  Serial.print(temp);
  Serial.println(F("°C "));   

  int raw= analogRead(phpin); 
  ph=map(raw,3200,1380,7,10);
  Serial.print("ph: ");
  Serial.println(ph);
  
  if (Firebase.ready()) 
  {
    
    Firebase.setInt(fbdo, "/test/turb",turbidity );
    Firebase.setInt(fbdo, "/test/tds", tdsValue);
    Firebase.setInt(fbdo, "/test/temperature", temp);
    Firebase.setInt(fbdo, "/test/ph", ph);
  }
}


void stopMotors() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

// Blynk virtual button handlers
BLYNK_WRITE(V1) {  // Forward
  if (param.asInt() == 1) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    stopMotors();
  }
}

BLYNK_WRITE(V2) {  // Backward
  if (param.asInt() == 1) {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
  } else {
    stopMotors();
  }
}

BLYNK_WRITE(V3) {  // Left
  if (param.asInt() == 1) {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    stopMotors();
  }
}

BLYNK_WRITE(V4) {  // Right
  if (param.asInt() == 1) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
  } else {
    stopMotors();
  }
}
BLYNK_WRITE(V0) {  // Left
  if (param.asInt() == 1) {
    digitalWrite(mot, HIGH);
  } else {
    digitalWrite(mot, LOW);
  }
}
